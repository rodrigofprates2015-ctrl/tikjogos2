function generateUID(): string {
  return 'user-' + Math.random().toString(36).substr(2, 9)
                 + Date.now().toString(36);
  // Example: 'user-k7x2m9qp41kzf8'
  // Format:  'user-' + 9 random base36 chars + timestamp in base36
  // NOT cryptographically secure — collision risk is low but possible
  // NOT persisted — a page refresh generates a new UID
}

setUser: (name: string) => {
  const uid = generateUID();
  set({ user: { uid, name } });
  // No localStorage persistence of uid — only name is saved via saveNickname()
}
