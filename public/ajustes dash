import { db } from './db';
import { sql } from 'drizzle-orm';

/**
 * Serviço de Analytics para Lobbies
 * Responsável por registrar e recuperar dados de salas
 */

export interface LobbyTrackingEvent {
  roomCode: string;
  eventType: 'room_created' | 'player_joined' | 'player_left' | 'game_started' | 'game_ended' | 'room_closed';
  playerId?: string;
  playerName?: string;
  themeName?: string;
  gameResult?: any;
}

/**
 * Registra criação de uma nova sala
 */
export async function trackRoomCreated(
  roomCode: string,
  hostId: string,
  hostName: string,
  gameMode: string
) {
  try {
    console.log(`[Analytics] Tracking room creation: ${roomCode} by ${hostName}`);
    
    await db.execute(sql`
      INSERT INTO room_analytics (room_code, created_at, host_id, host_name, game_mode, status)
      VALUES (${roomCode}, NOW(), ${hostId}, ${hostName}, ${gameMode}, 'active')
      ON CONFLICT (room_code) DO NOTHING
    `);
    
    console.log(`[Analytics] ✅ Room ${roomCode} registered`);
  } catch (error) {
    console.error(`[Analytics] ❌ Error tracking room creation:`, error);
  }
}

/**
 * Registra entrada de jogador em uma sala
 */
export async function trackPlayerJoined(
  roomCode: string,
  playerId: string,
  playerName: string
) {
  try {
    console.log(`[Analytics] Tracking player join: ${playerName} in ${roomCode}`);
    
    // Inserir na tabela lobby_players
    await db.execute(sql`
      INSERT INTO lobby_players (room_code, player_id, player_name, joined_at, status)
      VALUES (${roomCode}, ${playerId}, ${playerName}, NOW(), 'active')
    `);
    
    // Incrementar contador de jogadores únicos em room_analytics
    await db.execute(sql`
      UPDATE room_analytics 
      SET unique_players = (
        SELECT COUNT(DISTINCT player_id) FROM lobby_players WHERE room_code = ${roomCode}
      ),
      total_players = (
        SELECT COUNT(*) FROM lobby_players WHERE room_code = ${roomCode} AND status = 'active'
      )
      WHERE room_code = ${roomCode}
    `);
    
    console.log(`[Analytics] ✅ Player ${playerName} joined ${roomCode}`);
  } catch (error) {
    console.error(`[Analytics] ❌ Error tracking player join:`, error);
  }
}

/**
 * Registra saída de jogador da sala
 */
export async function trackPlayerLeft(
  roomCode: string,
  playerId: string
) {
  try {
    console.log(`[Analytics] Tracking player left: ${playerId} from ${roomCode}`);
    
    // Calcular duração da sessão
    const result = await db.execute(sql`
      SELECT 
        EXTRACT(EPOCH FROM (NOW() - joined_at))::INT as duration,
        player_name
      FROM lobby_players
      WHERE room_code = ${roomCode} AND player_id = ${playerId} AND status = 'active'
      LIMIT 1
    `);
    
    const sessionDuration = result.rows[0]?.duration || 0;
    
    // Atualizar status do jogador
    await db.execute(sql`
      UPDATE lobby_players
      SET left_at = NOW(), 
          status = 'left',
          session_duration = ${sessionDuration}
      WHERE room_code = ${roomCode} AND player_id = ${playerId}
    `);
    
    // Recalcular totais
    await db.execute(sql`
      UPDATE room_analytics 
      SET total_players = (
        SELECT COUNT(*) FROM lobby_players 
        WHERE room_code = ${roomCode} AND status = 'active'
      ),
      total_session_duration = COALESCE((
        SELECT SUM(session_duration) FROM lobby_players 
        WHERE room_code = ${roomCode}
      ), 0)
      WHERE room_code = ${roomCode}
    `);
    
    console.log(`[Analytics] ✅ Player left ${roomCode}, duration: ${sessionDuration}s`);
  } catch (error) {
    console.error(`[Analytics] ❌ Error tracking player left:`, error);
  }
}

/**
 * Registra início de um jogo na sala
 */
export async function trackGameStarted(
  roomCode: string,
  themeName: string
) {
  try {
    console.log(`[Analytics] Tracking game start: ${themeName} in ${roomCode}`);
    
    // Registrar evento
    await db.execute(sql`
      INSERT INTO game_events (room_code, event_type, theme_name)
      VALUES (${roomCode}, 'game_started', ${themeName})
    `);
    
    // Adicionar tema à lista de temas jogados
    await db.execute(sql`
      UPDATE room_analytics 
      SET themes_played = CASE 
        WHEN themes_played @> jsonb_build_array(${themeName})
        THEN themes_played
        ELSE themes_played || jsonb_build_array(${themeName})
      END
      WHERE room_code = ${roomCode}
    `);
    
    console.log(`[Analytics] ✅ Game started with theme: ${themeName}`);
  } catch (error) {
    console.error(`[Analytics] ❌ Error tracking game start:`, error);
  }
}

/**
 * Registra fim de um jogo e incrementa contador
 */
export async function trackGameEnded(
  roomCode: string,
  gameResult: any
) {
  try {
    console.log(`[Analytics] Tracking game end in ${roomCode}`);
    
    // Registrar evento com resultado
    await db.execute(sql`
      INSERT INTO game_events (room_code, event_type, game_result)
      VALUES (${roomCode}, 'game_ended', ${JSON.stringify(gameResult)}::jsonb)
    `);
    
    // Incrementar contador de jogos
    await db.execute(sql`
      UPDATE room_analytics 
      SET games_played = games_played + 1
      WHERE room_code = ${roomCode}
    `);
    
    console.log(`[Analytics] ✅ Game ended in ${roomCode}`);
  } catch (error) {
    console.error(`[Analytics] ❌ Error tracking game end:`, error);
  }
}

/**
 * Registra fechamento de sala
 */
export async function trackRoomClosed(roomCode: string) {
  try {
    console.log(`[Analytics] Tracking room close: ${roomCode}`);
    
    // Calcular média de duração de sessão
    const result = await db.execute(sql`
      SELECT 
        AVG(session_duration)::INT as avg_duration,
        COUNT(DISTINCT player_id) as total_unique,
        SUM(CASE WHEN status = 'active' THEN 1 ELSE 0 END) as active_count
      FROM lobby_players
      WHERE room_code = ${roomCode}
    `);
    
    const avgDuration = result.rows[0]?.avg_duration || 0;
    
    // Fechar sala
    await db.execute(sql`
      UPDATE room_analytics 
      SET status = 'closed', 
          ended_at = NOW(),
          avg_session_duration = ${avgDuration}
      WHERE room_code = ${roomCode}
    `);
    
    console.log(`[Analytics] ✅ Room ${roomCode} closed`);
  } catch (error) {
    console.error(`[Analytics] ❌ Error tracking room close:`, error);
  }
}

/**
 * Busca relatório completo de um lobby
 */
export async function getLobbyReport(roomCode: string) {
  try {
    const result = await db.execute(sql`
      SELECT 
        ra.*,
        (SELECT COUNT(DISTINCT player_id) FROM lobby_players WHERE room_code = ${roomCode}) as total_unique_players,
        (SELECT jsonb_agg(DISTINCT jsonb_build_object(
          'playerName', player_name,
          'joinedAt', joined_at,
          'leftAt', left_at,
          'sessionDuration', session_duration
        )) FROM lobby_players WHERE room_code = ${roomCode}) as players_list,
        (SELECT jsonb_agg(jsonb_build_object(
          'eventType', event_type,
          'themeName', theme_name,
          'createdAt', created_at
        )) FROM game_events WHERE room_code = ${roomCode}) as events_list
      FROM room_analytics ra
      WHERE room_code = ${roomCode}
      LIMIT 1
    `);
    
    return result.rows[0] || null;
  } catch (error) {
    console.error(`[Analytics] ❌ Error fetching lobby report:`, error);
    return null;
  }
}

/**
 * Busca relatório agregado de múltiplos lobbies (com filtros)
 */
export async function getLobbiesReport(filters: {
  startDate?: Date;
  endDate?: Date;
  gameMode?: string;
  status?: string;
  limit?: number;
} = {}) {
  try {
    let query = `
      SELECT 
        ra.*,
        (SELECT COUNT(*) FROM lobby_players WHERE room_code = ra.room_code) as total_players_all,
        (SELECT COUNT(DISTINCT player_id) FROM lobby_players WHERE room_code = ra.room_code) as unique_players_count
      FROM room_analytics ra
      WHERE 1=1
    `;
    
    const params: any[] = [];
    let paramIndex = 1;
    
    if (filters.startDate) {
      query += ` AND ra.created_at >= $${paramIndex}`;
      params.push(filters.startDate);
      paramIndex++;
    }
    
    if (filters.endDate) {
      query += ` AND ra.created_at <= $${paramIndex}`;
      params.push(filters.endDate);
      paramIndex++;
    }
    
    if (filters.gameMode) {
      query += ` AND ra.game_mode = $${paramIndex}`;
      params.push(filters.gameMode);
      paramIndex++;
    }
    
    if (filters.status) {
      query += ` AND ra.status = $${paramIndex}`;
      params.push(filters.status);
      paramIndex++;
    }
    
    query += ` ORDER BY ra.created_at DESC`;
    
    if (filters.limit) {
      query += ` LIMIT $${paramIndex}`;
      params.push(filters.limit);
    }
    
    const result = await db.execute(sql.raw(query, params));
    return result.rows;
  } catch (error) {
    console.error(`[Analytics] ❌ Error fetching lobbies report:`, error);
    return [];
  }
}
